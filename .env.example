# NuCRM Environment Variables
# Copy this file to .env.local and fill in your values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEV QUICK START
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Copy this file: cp .env.example .env.local
# 2. Set DATABASE_URL to your local PostgreSQL:
#      DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nucrm
# 3. Run migrations: npm run db:migrate
# 4. Seed dev data: npm run seed:dev
# 5. Start the app: npm run dev
#
# Notes:
# - SENTRY_DSN is optional for local development
# - Set SENTRY_ENABLE=false to disable Sentry entirely in dev
# - Most third-party keys (Resend, Twilio, etc.) are not needed for local dev
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Database (PostgreSQL)
# Local dev example: postgresql://postgres:postgres@localhost:5432/nucrm
DATABASE_URL=postgresql://user:password@host:5432/nucrm
DATABASE_SSL=true
DATABASE_POOL_SIZE=5

# Authentication — NEVER use weak/dev secrets in any environment
# Generate with: openssl rand -base64 64
JWT_SECRET=
# Generate with: openssl rand -base64 48
SESSION_SECRET=
# Generate with: openssl rand -hex 32
SETUP_KEY=
# Generate with: openssl rand -base64 64
CRON_SECRET=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=production

# Redis
REDIS_URL=redis://host:6379

# Email (Resend)
RESEND_API_KEY=re_xxxxxx


# WhatsApp (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Voice (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Storage (S3/R2)
BACKUP_BUCKET=nucrm-backups
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto
# For Cloudflare R2:
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# Backup settings
BACKUP_KEEP_DAYS=30

# ── Sentry (Error Tracking) ────────────────────────────
# Get your DSN from: https://sentry.io
# Optional for local development - set SENTRY_ENABLE=false to skip
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=nucrm
SENTRY_PROJECT=nucrm-app
SENTRY_AUTH_TOKEN=
# Set to false to disable Sentry in development
SENTRY_ENABLE=true
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Critical Error Alerts (Webhook) ────────────────────
# When set, fatal errors will POST to this URL with message, stack trace, timestamp, and environment
# Rate-limited to 1 alert per 60 seconds per error type (message prefix)
CRITICAL_ERROR_WEBHOOK_URL=https://hooks.example.com/critical-errors

# ── Grafana (Monitoring) ───────────────────────────────
GRAFANA_ADMIN_USER=admin  # Change this in production
GRAFANA_ADMIN_PASSWORD=generate-a-random-password-here

# ── Stripe (Billing) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxx

# ── Encryption (Backup Security) ───────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Webhook Secrets ────────────────────────────────────
RESEND_WEBHOOK_SECRET=
WHATSAPP_APP_SECRET=
