{
  "info": {
    "name": "NuCRM Enterprise API",
    "description": "Complete API collection for NuCRM Enterprise CRM.\n\n## Authentication\n- **JWT**: Login via /api/auth/login, cookie `nucrm_session` auto-stored\n- **API Key**: Use `Authorization: Bearer ak_live_xxxxx` header\n\n## Security Best Practices\n- Always use HTTPS in production\n- API keys have scoped permissions (contacts:read, deals:all, etc.)\n- CSRF tokens required for state-changing requests (auto-handled via cookie)\n- Rate limited to 100 req/min per user\n- Row-Level Security (RLS) ensures tenant data isolation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "Authorization",
        "type": "string"
      },
      {
        "key": "value",
        "value": "Bearer {{api_key}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "00 - Auth Setup",
      "description": "Login and get session token for all subsequent requests",
      "item": [
        {
          "name": "Login (Super Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.environment.set('auth_status', 'authenticated');",
                  "});",
                  "",
                  "// Extract session cookie for other requests",
                  "if (pm.response.code === 200) {",
                  "    console.log('Session cookie set automatically');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Org Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"a@a.com\",\n  \"password\": \"Vinayak@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get CSRF Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/csrf-token",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "csrf-token"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CSRF token retrieved', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var data = pm.response.json();",
                  "    if (data.token) {",
                  "        pm.environment.set('csrf_token', data.token);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tenant/me",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User info retrieved', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var data = pm.response.json();",
                  "    console.log('User:', JSON.stringify(data, null, 2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "01 - API Keys",
      "description": "Manage API keys for external access. Keys are scoped and can be revoked.",
      "item": [
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tenant/api-keys",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "api-keys"]
            }
          }
        },
        {
          "name": "Create API Key (Full Access)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"postman-test-key\",\n  \"scopes\": [\"*\"],\n  \"expires_in_days\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tenant/api-keys",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "api-keys"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API key created', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var data = pm.response.json();",
                  "    if (data.key) {",
                  "        console.log('⚠️ SAVE THIS KEY (shown once):', data.key);",
                  "        console.log('Key prefix:', data.prefix);",
                  "        // Uncomment next line to auto-set for testing:",
                  "        // pm.environment.set('api_key', data.key);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create API Key (Read-Only Contacts)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"readonly-contacts\",\n  \"scopes\": [\"contacts:read\", \"contacts:list\"],\n  \"expires_in_days\": 7\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tenant/api-keys",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "api-keys"]
            }
          }
        },
        {
          "name": "Create API Key (Scoped - Deals + Contacts)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"sales-team-key\",\n  \"scopes\": [\"contacts:read\", \"contacts:write\", \"deals:all\", \"leads:all\"],\n  \"expires_in_days\": 90\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tenant/api-keys",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "api-keys"]
            }
          }
        },
        {
          "name": "Test API Key Auth",
          "request": {
            "method": "GET",
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "key",
                  "value": "Authorization",
                  "type": "string"
                },
                {
                  "key": "value",
                  "value": "Bearer {{api_key}}",
                  "type": "string"
                },
                {
                  "key": "in",
                  "value": "header",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/tenant/contacts?limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "contacts"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/tenant/api-keys/KEY_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "api-keys", "KEY_ID_HERE"]
            }
          }
        }
      ]
    },
    {
      "name": "02 - Contacts",
      "description": "CRUD operations for contacts with full RBAC",
      "item": [
        {
          "name": "List Contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tenant/contacts?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "tenant", "contacts"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "sort", "value": "createdAt:desc", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Contacts list retrieved', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var data = pm.response.json();",
