{
  "name": "nucrm-enterprise",
  "version": "1.0.0",
  "description": "Multi-tenant Enterprise CRM built with Next.js 16, PostgreSQL, and JWT auth",
  "author": "NuCRM Team",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/vinayakss007/nucrm-bigplan-by-vm-enterprise-v2#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinayakss007/nucrm-bigplan-by-vm-enterprise-v2.git"
  },
  "bugs": {
    "url": "https://github.com/vinayakss007/nucrm-bigplan-by-vm-enterprise-v2/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "crm",
    "saas",
    "multi-tenant",
    "nextjs",
    "postgresql",
    "typescript",
    "customer-relationship-management",
    "lead-management",
    "sales-pipeline"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 3300",
    "typecheck": "npx tsc --noEmit --pretty",
    "check": "npm run typecheck && npm run lint && npm run test:unit && echo '✅ All checks passed'",
    "premerge": "bash scripts/pre-merge-check.sh",
    "smoke": "bash scripts/smoke-test.sh",
    "db:push": "npx drizzle-kit push --config=./drizzle.config.ts",
    "db:generate": "npx tsx scripts/generate-migration.ts",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:rollback": "npx tsx scripts/rollback-migration.ts",
    "db:status": "npx tsx scripts/migration-status.ts",
    "db:auto": "npx tsx scripts/migrate.ts",
    "db:sync": "npx drizzle-kit push --config=./drizzle.config.ts",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "seed:e2e": "tsx scripts/seed-e2e-user.ts",
    "db:seed": "npx tsx scripts/seed-advanced.ts",
    "db:demo": "npx tsx scripts/seed-massive-data.ts",
    "db:studio": "node -e \"console.log('Use DBeaver or pgAdmin to connect: ' + process.env.DATABASE_URL)\"",
    "setup": "cp -n .env.example .env.local && npm run db:migrate && echo '\n✅ Run: npm run dev\n'",
    "prod:launch": "bash scripts/production-launch.sh",
    "prod:preflight": "npx tsx scripts/production-preflight.ts",
    "prod:start": "bash scripts/start-production.sh",
    "prod:start:custom": "NODE_OPTIONS='--max-old-space-size=2048' next start -H 127.0.0.1",
    "prod:seed": "npx tsx scripts/seed-massive-drizzle.ts",
    "demo:setup": "node setup-demo.js",
    "worker": "tsx worker.ts",
    "worker:dev": "tsx watch worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\" -c \"blue,bold.yellow\" -n \"APP,WORKER\"",
    "start:app": "next start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "logs:watch": "node scripts/watch-logs.js",
    "logs:errors": "node scripts/watch-logs.js error",
    "logs:view": "echo '📡 Opening log viewer... && open log-viewer.html || xdg-open log-viewer.html'",
    "analyze:bundle": "npm run build && npx tsx scripts/analyze-bundle.ts",
    "quality:report": "npx tsx scripts/quality-report.ts",
    "quality:lint": "npx eslint . --max-warnings 3300",
    "quality:full": "npm run typecheck && npm run quality:lint && npm run test && npm run quality:report",
    "lighthouse:audit": "npx tsx scripts/lighthouse-audit.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-table": "8.21.3",
    "@types/uuid": "^10.0.0",
    "@xyflow/react": "^12.10.2",
    "autoprefixer": "10.4.27",
    "bcryptjs": "3.0.3",
    "bullmq": "5.77.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "4.1.0",
    "dompurify": "^3.4.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "lucide-react": "0.511.0",
    "mathjs": "^14.9.1",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "nodemailer": "8.0.9",
    "pg": "^8.20.0",
    "pg-boss": "12.15.0",
    "postcss": "8.5.10",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "2.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "resend": "4.8.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.19",
    "tsx": "^4.21.0",
    "typed-function": "^4.2.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bcryptjs": "3.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "22.19.17",
    "@types/nodemailer": "6.4.23",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "2.1.8",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "26.1.0",
    "lighthouse": "^13.4.0",
    "playwright": "^1.59.1",
    "typescript": "5.9.3",
    "vitest": "2.1.8"
  },
  "overrides": {
    "vitest": "2.1.8",
    "ws": "^8.21.0"
  }
}
