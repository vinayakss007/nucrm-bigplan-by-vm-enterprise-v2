###############################################################################
#  NuCRM — Production Environment Variables
#  
#  VM Target: 8 GB RAM, 1 PostgreSQL, 1 Redis, 1 S3 (MinIO), 1 Email service
#  
#  INSTRUCTIONS:
#    1. Copy this file: cp deploy/.env.production .env
#    2. Fill in ALL values marked with <<<REQUIRED>>>
#    3. Generate secrets: bash deploy/generate-secrets.sh
#    4. Start: docker compose -f deploy/docker-compose.production.yml up -d
#
#  SECRET GENERATION (run once):
#    openssl rand -base64 64   → JWT_SECRET
#    openssl rand -base64 48   → SESSION_SECRET
#    openssl rand -hex 32      → ENCRYPTION_KEY
#    openssl rand -hex 24      → SETUP_KEY
#    openssl rand -hex 48      → CRON_SECRET
#    openssl rand -hex 32      → EMERGENCY_RECOVERY_KEY
###############################################################################

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 1: CORE APPLICATION                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Your public-facing domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://crm.yourdomain.com
ALLOWED_ORIGINS=https://crm.yourdomain.com

# Cookie security (true for HTTPS, false for HTTP-only dev)
COOKIE_SECURE=true

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 2: AUTHENTICATION & SECRETS                                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# JWT signing key — MINIMUM 64 chars, NEVER share
# Generate: openssl rand -base64 64
JWT_SECRET=<<<REQUIRED>>>

# Session encryption
# Generate: openssl rand -base64 48
SESSION_SECRET=<<<REQUIRED>>>

# First-time admin setup key (used once at /setup)
# Generate: openssl rand -hex 24
SETUP_KEY=<<<REQUIRED>>>

# Cron job authentication header
# Generate: openssl rand -hex 48
CRON_SECRET=<<<REQUIRED>>>

# Field-level encryption (API keys, SSO secrets, AI provider keys)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=<<<REQUIRED>>>

# Emergency recovery (last resort when all auth is broken)
# Generate: openssl rand -hex 32
EMERGENCY_RECOVERY_KEY=<<<REQUIRED>>>

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 3: DATABASE (PostgreSQL 16)                                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Connection string (Docker internal network)
DATABASE_URL=postgresql://nucrm:<<<POSTGRES_PASSWORD>>>@postgres:5432/nucrm?sslmode=disable

# External access (for tools like pgAdmin, DBeaver)
POSTGRES_USER=nucrm
POSTGRES_PASSWORD=<<<REQUIRED>>>
POSTGRES_DB=nucrm

# Pool tuning for 8GB VM (20 connections for app + 5 for worker + 5 for monitoring)
DATABASE_POOL_SIZE=20
DATABASE_SSL=true
DATABASE_STATEMENT_TIMEOUT=10000

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 4: REDIS                                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

REDIS_URL=redis://redis:6379
REDIS_MAXMEMORY=512mb

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 5: OBJECT STORAGE (S3 / MinIO)                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# For MinIO (self-hosted S3-compatible, included in docker-compose)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=<<<REQUIRED>>>
AWS_SECRET_ACCESS_KEY=<<<REQUIRED>>>

# Buckets (auto-created by MinIO init)
BACKUP_BUCKET=nucrm-backups
DOCUMENT_BUCKET=nucrm-documents
BACKUP_KEEP_DAYS=30
DOCUMENT_MAX_BYTES=104857600

# Public URL for presigned downloads (external access to MinIO)
S3_PUBLIC_URL=https://s3.yourdomain.com

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 6: EMAIL SERVICE                                                ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Option A: Resend (recommended for production)
RESEND_API_KEY=<<<REQUIRED>>>
RESEND_WEBHOOK_SECRET=

# Option B: SMTP fallback (if Resend unavailable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Email sender display
EMAIL_FROM_NAME=NuCRM
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 7: AI / LLM PROVIDERS                                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# The app supports multi-provider via the AI gateway.
# Configure at least ONE. Keys stored encrypted via ENCRYPTION_KEY.
# These are fallback defaults; tenants configure their own via UI.

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=<<<REQUIRED>>>

# Groq (fast inference)
GROQ_API_KEY=

# Ollama (self-hosted, optional)
OLLAMA_BASE_URL=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 8: ERROR TRACKING — SENTRY                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=<<<REQUIRED>>>
NEXT_PUBLIC_SENTRY_DSN=<<<REQUIRED>>>

# Organization + Project slug (for source map uploads)
SENTRY_ORG=<<<REQUIRED>>>
SENTRY_PROJECT=<<<REQUIRED>>>

# Auth token for CI/build source map upload
# Create at: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=<<<REQUIRED>>>

# Runtime controls
SENTRY_ENABLE=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 9: MONITORING — GRAFANA + PROMETHEUS                            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<<<REQUIRED>>>
GRAFANA_SERVER_ROOT_URL=https://grafana.yourdomain.com

# Prometheus (internal, no auth needed on Docker network)
PROMETHEUS_ENABLED=true

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 10: BILLING — STRIPE                                            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 11: MESSAGING INTEGRATIONS (optional)                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Telegram Bot (for admin notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Slack/Discord webhooks (for ops alerts)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 12: FEATURE FLAGS & LIMITS                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Usage limit enforcement (off = record only, on = block at limit + 402)
USAGE_LIMITS=on

# Module auto-install on signup (on = plan-based, off = legacy 3 modules)
MODULE_AUTO_INSTALL=on

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 13: INFRASTRUCTURE TUNING (8GB VM)                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Docker resource allocation
NUCRM_WEB_REPLICAS=2
NUCRM_WEB_MEMORY_LIMIT=768M
NUCRM_WEB_CPU_LIMIT=1.5
NUCRM_WORKER_REPLICAS=1
NUCRM_WORKER_MEMORY_LIMIT=512M
NUCRM_WORKER_CPU_LIMIT=0.5
NUCRM_PUBLIC_PORT=80
NUCRM_PUBLIC_SSL_PORT=443

# MinIO resource limits
MINIO_MEMORY_LIMIT=512M
